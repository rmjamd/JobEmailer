# Copy to .env in the project root and fill in your values.
# Spring Boot loads this via spring.config.import in application.properties.
# You can also export these as environment variables instead.

jobemailer.telegram-bot-token=

# @LinkedinDmBot — add as admin to your LinkedinDm channel (public: use @channelname below)
jobemailer.linkedin-dm-bot-token=
jobemailer.linkedin-dm-channel=@LinkedinDm
# Optional numeric id for private channels (run ./scripts/get-linkedin-dm-chat-id.sh)
# jobemailer.linkedin-dm-chat-id=-100xxxxxxxxxx

jobemailer.gemini-api-key=
jobemailer.gemini-api-keys=

jobemailer.smtp-email=
jobemailer.smtp-password=
